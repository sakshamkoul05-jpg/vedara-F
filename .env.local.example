# ============================================
# VEDARA RETREAT FRONTEND — ENVIRONMENT VARIABLES
# ============================================
# Copy to .env.local and fill in values
# NEXT_PUBLIC_* vars are exposed to the browser
# NEVER put secrets in NEXT_PUBLIC_* vars
# ============================================

# --- Backend API URL (public — visible to browser) ---
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# --- Razorpay Key ID (public — safe to expose) ---
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# --- Site URL (for SEO/meta tags) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
